# Ensure shell scripts and Python files use LF line endings even when checked
# out on Windows — they break on Linux otherwise.
*.sh        text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
LICENSE     text eol=lf
.gitignore  text eol=lf
